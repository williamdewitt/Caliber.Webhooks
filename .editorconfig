root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[*.{json,yml,yaml,csproj,props,targets,slnx,md}]
indent_size = 2

[*.md]
trim_trailing_whitespace = false

[*.cs]
# Namespaces & usings
csharp_style_namespace_declarations = file_scoped:warning
dotnet_sort_system_directives_first = true
csharp_using_directive_placement = outside_namespace:warning

# Prefer modern, expressive C#
csharp_style_var_when_type_is_apparent = true:suggestion
dotnet_style_prefer_conditional_expression_over_assignment = true:suggestion
dotnet_style_readonly_field = true:warning
csharp_prefer_braces = true:suggestion

# Naming: async methods, constants, interfaces handled by analyzers/Meziantou defaults

# Test projects: relax rules that fight idiomatic test naming/shape
[tests/**.cs]
# CA1707: underscores in member names — standard, readable test method naming
dotnet_diagnostic.CA1707.severity = none
# CA1515: types can be internal — not relevant for test classes
dotnet_diagnostic.CA1515.severity = none
# xUnit1051: threading TestContext.Current.CancellationToken through every call is noise for fast unit tests
dotnet_diagnostic.xUnit1051.severity = none
# MA0004: ConfigureAwait(false) is unnecessary in xUnit v3 tests (no sync context); library code still honours it
dotnet_diagnostic.MA0004.severity = none
